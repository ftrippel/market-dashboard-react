# Massive Economy API Configuration
# Optional: Set this to your Massive API key to fetch full yield curve data and thematic/crypto details.
# If not set, the script will fall back to yfinance + FRED.
MASSIVE_API_KEY=

# Live price refresh (Yahoo Finance overlay when LIVE is enabled)
# VITE_LIVE_DATA_REFRESH_MS=1000
# VITE_LIVE_DATA_IDLE_RETRY_MS=2000

# Local Fetch Tuning / Rate Limit Throttling
# Adjust these if you encounter Yahoo Finance API rate limits.
# YF_BATCH_SIZE=25
# YF_BATCH_PAUSE=1.0
# YF_INFO_PAUSE=0.3
# YF_HOLDINGS_PAUSE=0.4
